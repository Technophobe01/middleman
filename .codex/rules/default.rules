prefix_rule(
    pattern=["git", "commit", "--no-verify"],
    decision="forbidden",
    justification="middleman commits must run repository hooks",
    match=[
        "git commit --no-verify -m test",
    ],
)

prefix_rule(
    pattern=["git", "commit", "--amend"],
    decision="forbidden",
    justification="middleman workflow requires new commits instead of amending history",
    match=[
        "git commit --amend -m test",
    ],
)

prefix_rule(
    pattern=["git", ["status", "diff", "add"]],
    decision="allow",
    justification="middleman Codex worktrees may store git metadata outside the visible worktree",
    match=[
        "git status --short --branch",
        "git diff --stat",
        "git add internal/server/api_test.go",
    ],
)

prefix_rule(
    pattern=["git", "commit", ["-m", "-F"]],
    decision="allow",
    justification="middleman Codex worktrees may store git metadata outside the visible worktree",
    match=[
        "git commit -m test",
        "git commit -F /tmp/middleman-commit-message",
    ],
)

prefix_rule(
    pattern=["go", "test"],
    decision="allow",
    justification="middleman tests use workspace fixtures backed by repository git metadata",
    match=[
        "go test ./internal/server -shuffle=on",
        "go test ./internal/workspace/localruntime ./internal/server -shuffle=on",
    ],
)

prefix_rule(
    pattern=["make", ["test", "test-short", "test-integration"]],
    decision="allow",
    justification="middleman make test targets run Go tests that may need repository git metadata",
    match=[
        "make test",
        "make test-short",
        "make test-integration",
    ],
)
